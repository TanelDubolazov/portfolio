---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Tanel Dubolazov — Software Engineer',
  description:
    'Software engineer with a full-stack background and DevOps focus. Go, React, Docker, AWS, CI/CD.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="pt-28 pb-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900">Tanel Dubolazov</h1>
      <p class="mt-2 text-xl text-gray-500">Software Engineer</p>
      <p class="mt-6 text-lg text-gray-700 max-w-2xl leading-relaxed">
        Full-stack developer with a DevOps mindset. I build backend services in Go, frontend apps in React,
        and wire it all together with Docker, CI/CD, and cloud infrastructure.
        Previously 5+ years in e-commerce and digital marketing. I understand both the technical and business side.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact#form" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">Hire Me</a>
        <a href="/activity" class="px-5 py-2.5 border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium rounded-lg transition-colors">View Projects</a>
        <a href="https://github.com/TanelDubolazov" target="_blank" class="px-5 py-2.5 border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium rounded-lg transition-colors">GitHub</a>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Technical Skills</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Languages</h3>
          <p class="text-gray-600">Go, JavaScript/TypeScript, Bash, SQL</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Backend</h3>
          <p class="text-gray-600">REST APIs, WebSockets, Gin, Node.js, Express</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Frontend</h3>
          <p class="text-gray-600">React, Vite, Tailwind CSS, Astro</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Databases</h3>
          <p class="text-gray-600">PostgreSQL, SQLite, MySQL</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">DevOps & Cloud</h3>
          <p class="text-gray-600">Docker, GitHub Actions, Terraform, AWS (S3, CloudFront, EC2)</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Tools</h3>
          <p class="text-gray-600">Git, Vagrant, Postman, Cisco networking</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section id="projects" class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-10">Projects</h2>

      <!-- Gunn-MX Motocross Store -->
      <div class="mb-12 md:grid md:grid-cols-5 md:gap-8 items-start">
        <div class="md:col-span-2 mb-4 md:mb-0">
          <img src="/images/Motocross-store.png" alt="Gunn-MX motocross e-commerce store" class="project-img rounded-lg border border-gray-200 w-full" loading="lazy" />
          <img src="/images/Motocross-store-warehouse.png" alt="Gunn-MX warehouse management panel" class="project-img rounded-lg border border-gray-200 w-full mt-3" loading="lazy" />
        </div>
        <div class="md:col-span-3">
          <h3 class="text-xl font-bold text-gray-900">Gunn MX Motocross service    Store</h3>
          <p class="mt-1 text-sm text-gray-500">Solo project</p>
          <p class="mt-3 text-gray-700">
            Full-stack e-commerce application for a motocross parts store. Customers can browse products filtered by bike compatibility,
            add items to cart, and check out with multiple payment and shipping options.
            The admin side includes a warehouse management panel for inventory, orders, and shipment tracking.
          </p>
          <ul class="mt-3 space-y-1 text-sm text-gray-600">
            <li>Go backend with REST API and authentication</li>
            <li>React + TypeScript frontend</li>
            <li>Relational database, admin tooling</li>
            <li>Docker containerized, automated build pipeline</li>
          </ul>
          <div class="mt-4">
            <a href="https://gunnmx.ee" target="_blank" class="text-sm text-blue-600 hover:underline">Visit Site</a>
          </div>
        </div>
      </div>

      <!-- Social Network -->
      <div class="mb-12 md:grid md:grid-cols-5 md:gap-8 items-start">
        <div class="md:col-span-2 mb-4 md:mb-0">
          <img src="/images/social-network.png" alt="Social network platform" class="project-img rounded-lg border border-gray-200 w-full" loading="lazy" />
        </div>
        <div class="md:col-span-3">
          <h3 class="text-xl font-bold text-gray-900">Social Network</h3>
          <p class="mt-1 text-sm text-gray-500">Team project (2 developers) — kood/Jõhvi</p>
          <p class="mt-3 text-gray-700">
            Facebook-style social platform with profiles, posts with privacy controls, follow system, groups, events,
            and real-time chat via WebSockets. Built as part of the kood/Jõhvi curriculum.
          </p>
          <ul class="mt-3 space-y-1 text-sm text-gray-600">
            <li>Go backend (stdlib HTTP server), gorilla/websocket for real-time features</li>
            <li>React 18 frontend with Material UI</li>
            <li>SQLite with golang-migrate for schema management</li>
            <li>Containerized with Docker Compose</li>
          </ul>
          <div class="mt-4">
            <a href="https://github.com/TanelDubolazov/social-network" target="_blank" class="text-sm text-blue-600 hover:underline">View on GitHub</a>
          </div>
        </div>
      </div>

      <!-- CRUD Master -->
      <div class="mb-12 md:grid md:grid-cols-5 md:gap-8 items-start">
        <div class="md:col-span-2 mb-4 md:mb-0">
          <img src="/images/crud-master-diagram.png" alt="CRUD Master microservices architecture" class="project-img rounded-lg border border-gray-200 w-full" loading="lazy" />
        </div>
        <div class="md:col-span-3">
          <h3 class="text-xl font-bold text-gray-900">CRUD Master Microservices API</h3>
          <p class="mt-1 text-sm text-gray-500">Solo project — kood/Jõhvi</p>
          <p class="mt-3 text-gray-700">
            Microservices-based movie streaming API with an API Gateway for request routing and RabbitMQ for async messaging
            between services. Provisioned across three VMs using Vagrant.
          </p>
          <ul class="mt-3 space-y-1 text-sm text-gray-600">
            <li>Node.js services (API Gateway, Inventory, Billing)</li>
            <li>PostgreSQL databases per service</li>
            <li>RabbitMQ for inter-service messaging</li>
            <li>Vagrant for multi-VM provisioning</li>
          </ul>
          <div class="mt-4">
            <a href="https://github.com/TanelDubolazov/crud-master" target="_blank" class="text-sm text-blue-600 hover:underline">View on GitHub</a>
          </div>
        </div>
      </div>

      <div class="text-center">
        <a href="/activity" class="text-sm text-blue-600 hover:underline">All projects & GitHub activity →</a>
      </div>
    </div>
  </section>

  <!-- Education & Experience -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Education</h2>
          <div>
            <h3 class="font-semibold text-gray-900">kood/Jõhvi</h3>
            <p class="text-sm text-gray-500">Full-Stack Development, DevOps specialization</p>
            <p class="text-sm text-gray-500">2023 – 2025</p>
            <p class="mt-2 text-gray-600 text-sm">
              Intensive peer-learning program. Built 20+ projects in Go and JavaScript covering
              backend systems, frontend apps, networking, Docker, and CI/CD.
            </p>
            <a href="/certs/graduation-diploma.pdf" target="_blank" rel="noopener noreferrer"
              class="inline-block mt-3 text-sm text-blue-600 hover:underline">
              View Graduation Diploma
            </a>
          </div>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Experience</h2>
          <div class="mb-6">
            <h3 class="font-semibold text-gray-900">Student Developer & Auditor</h3>
            <p class="text-sm text-gray-500">kood/Jõhvi — 2023 – 2025</p>
            <p class="mt-2 text-gray-600 text-sm">
              Full-stack projects with strict deadlines in Agile teams. Performed code reviews and technical audits for peers.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900">Marketing Specialist</h3>
            <p class="text-sm text-gray-500">Freelance — 2018 – 2023</p>
            <p class="mt-2 text-gray-600 text-sm">
              Built and managed Shopify stores, ran data-driven ad campaigns, handled product databases and pricing automation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CallToAction
    title="Open for work"
    subtitle="Available for backend, full-stack, or DevOps engineering roles."
    actions={[
      { variant: 'primary', text: 'Contact Me', href: '/contact#form' },
      { text: 'View Projects', href: '/activity' },
    ]}
    classes={{ container: 'max-w-xl' }}
  />
</Layout>

<style>
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .lightbox-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .lightbox-overlay img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 0.5rem;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
  }
</style>

<div class="lightbox-overlay" id="lightbox">
  <img src="" alt="" id="lightbox-img" />
</div>

<script>
  const overlay = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;

  document.querySelectorAll('.project-img').forEach((img) => {
    (img as HTMLElement).style.cursor = 'zoom-in';
    img.addEventListener('click', () => {
      lbImg.src = (img as HTMLImageElement).src;
      lbImg.alt = (img as HTMLImageElement).alt;
      overlay.classList.add('active');
    });
  });

  overlay.addEventListener('click', () => {
    overlay.classList.remove('active');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') overlay.classList.remove('active');
  });
</script>
