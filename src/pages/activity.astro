---
import Layout from '~/layouts/PageLayout.astro';
import fs from 'fs';
import yaml from 'yaml';

// Load dynamic goals from YAML file
const goalsFile = fs.readFileSync('./goals.yaml', 'utf8');
const { goals } = yaml.parse(goalsFile);

// Load GitHub activity data (generated by scripts/fetch-github-activity.mjs)
let ghData = null;
try {
  const ghFile = fs.readFileSync('./src/data/github-activity.json', 'utf8');
  ghData = JSON.parse(ghFile);
} catch {
  // Will be generated on next build via GitHub Actions
}

// Calculate progress for each goal
const goalsWithProgress = goals.map((goal) => {
  const totalMilestones = goal.milestones.length;
  const completedMilestones = goal.milestones.filter((ms) => ms.completed).length;
  const progressPercent = Math.round((completedMilestones / totalMilestones) * 100);
  return { ...goal, progress: progressPercent };
});

// Format date
const formatDate = (dateStr) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

// Relative time for GitHub activity
const timeAgo = (dateStr) => {
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / 86400000);
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays}d ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)}w ago`;
  return `${Math.floor(diffDays / 30)}mo ago`;
};

// Language colour map
const langColors: Record<string, string> = {
  Go: '#00ADD8',
  JavaScript: '#F7DF1E',
  TypeScript: '#3178C6',
  Python: '#3572A5',
  Astro: '#FF5D01',
  HTML: '#E34C26',
  CSS: '#563D7C',
  Shell: '#89E051',
  Dockerfile: '#384D54',
  Rust: '#DEA584',
  Vue: '#41B883',
  Svelte: '#FF3E00',
  Java: '#B07219',
  C: '#555555',
  'C++': '#F34B7D',
  Ruby: '#701516',
  PHP: '#4F5D95',
  Kotlin: '#A97BFF',
  Swift: '#F05138',
  Dart: '#00B4AB',
  Lua: '#000080',
  SCSS: '#C6538C',
};

// Format bytes to human readable
const formatBytes = (bytes: number) => {
  if (bytes >= 1_000_000) return `${(bytes / 1_000_000).toFixed(1)}MB`;
  if (bytes >= 1_000) return `${(bytes / 1_000).toFixed(0)}KB`;
  return `${bytes}B`;
};

// Compute language percentages for the bar
const langPercentages = ghData?.languages ? (() => {
  const total = ghData.languages.reduce((sum, l) => sum + l.bytes, 0);
  return ghData.languages.map((l) => ({ ...l, pct: ((l.bytes / total) * 100) }));
})() : [];

const metadata = {
  title: 'Projects',
  description: 'Active projects, GitHub contributions, and professional milestones.',
};
---

<Layout metadata={metadata}>
  <!-- Header — clean, no emoji, no gradients -->
  <section class="pt-24 pb-12 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">Projects</h1>
      <p class="mt-3 text-lg text-gray-500">
        What I'm building, what I've shipped, and where I'm heading.
      </p>
    </div>
  </section>

  {/* ===== GitHub Overview ===== */}
  {ghData && (
    <>
      {/* Compact stat row */}
      <section class="pb-10 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="flex flex-wrap gap-6 text-sm text-gray-600 border-b border-gray-200 pb-6">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.25.25 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" /></svg>
              <strong class="text-gray-900">{ghData.stats.totalRepos}</strong> repositories
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" /></svg>
              <strong class="text-gray-900">{ghData.stats.publicRepos}</strong> public
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M4 4a4 4 0 0 1 8 0v2h.25c.966 0 1.75.784 1.75 1.75v5.5A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.25v-5.5C2 6.784 2.784 6 3.75 6H4Zm8.25 3.5h-8.5a.25.25 0 0 0-.25.25v5.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-5.5a.25.25 0 0 0-.25-.25ZM10.5 6V4a2.5 2.5 0 1 0-5 0v2Z" /></svg>
              <strong class="text-gray-900">{ghData.stats.privateRepos}</strong> private
            </span>
            {ghData.stats.currentStreak > 0 && (
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M9.504.43a1.516 1.516 0 0 1 2.437 1.713L10.415 5.5h2.123c1.57 0 2.346 1.909 1.22 3.004l-7.34 7.142a1.249 1.249 0 0 1-.871.354h-.302a1.25 1.25 0 0 1-1.157-1.723L5.633 10.5H3.462c-1.57 0-2.346-1.909-1.22-3.004Z" /></svg>
                <strong class="text-gray-900">{ghData.stats.currentStreak}</strong>-day streak
              </span>
            )}
            <span class="ml-auto text-xs text-gray-400">
              Updated {formatDate(ghData.generatedAt)}
            </span>
          </div>
        </div>
      </section>

      {/* Recent Repos — compact cards with top languages */}
      <section class="pb-16 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Recently active</h2>

          <div class="grid gap-3 sm:grid-cols-2">
            {ghData.recentRepos.map((repo) => (
              <div class={`group rounded-lg border p-4 transition-colors ${
                repo.isPrivate
                  ? 'border-gray-200 bg-gray-50'
                  : 'border-gray-200 hover:border-blue-300'
              }`}>
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0">
                    {repo.isPrivate ? (
                      <span class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-400">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16"><path d="M4 4a4 4 0 0 1 8 0v2h.25c.966 0 1.75.784 1.75 1.75v5.5A1.75 1.75 0 0 1 12.25 15h-8.5A1.75 1.75 0 0 1 2 13.25v-5.5C2 6.784 2.784 6 3.75 6H4Zm8.25 3.5h-8.5a.25.25 0 0 0-.25.25v5.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-5.5a.25.25 0 0 0-.25-.25ZM10.5 6V4a2.5 2.5 0 1 0-5 0v2Z" /></svg>
                        Private project
                      </span>
                    ) : (
                      <a href={repo.url} target="_blank" rel="noopener noreferrer"
                         class="text-sm font-medium text-gray-900 group-hover:text-blue-600 transition-colors truncate block">
                        {repo.name}
                      </a>
                    )}
                    {repo.description && (
                      <p class="text-xs text-gray-500 mt-1 line-clamp-1">{repo.description}</p>
                    )}
                  </div>
                  <span class="text-xs text-gray-400 whitespace-nowrap shrink-0">
                    {timeAgo(repo.pushedAt)}
                  </span>
                </div>

                {/* Top languages for this repo */}
                {repo.languages && repo.languages.length > 0 ? (
                  <div class="flex flex-wrap items-center gap-2 mt-2.5">
                    {repo.languages.map((lang) => (
                      <span class="flex items-center gap-1 text-xs text-gray-400">
                        <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${langColors[lang.name] || '#8b8b8b'}`}></span>
                        {lang.name}
                      </span>
                    ))}
                  </div>
                ) : repo.language ? (
                  <div class="flex items-center gap-1 mt-2.5 text-xs text-gray-400">
                    <span class="w-2 h-2 rounded-full" style={`background-color: ${langColors[repo.language] || '#8b8b8b'}`}></span>
                    {repo.language}
                  </div>
                ) : null}
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Languages & Technologies */}
      {ghData.languages && ghData.languages.length > 0 && (
        <section class="pb-16 bg-white">
          <div class="container mx-auto px-4 max-w-4xl">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">Languages & technologies</h2>

            {/* Stacked bar */}
            <div class="flex h-3 rounded-full overflow-hidden mb-4">
              {langPercentages.filter((l) => l.pct >= 1).map((lang) => (
                <div
                  class="h-full transition-all"
                  style={`width: ${lang.pct}%; background-color: ${langColors[lang.name] || '#8b8b8b'}`}
                  title={`${lang.name} ${lang.pct.toFixed(1)}%`}
                />
              ))}
            </div>

            {/* Legend */}
            <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
              {langPercentages.filter((l) => l.pct >= 1).map((lang) => (
                <span class="flex items-center gap-1.5 text-gray-600">
                  <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background-color: ${langColors[lang.name] || '#8b8b8b'}`}></span>
                  {lang.name}
                  <span class="text-gray-400">{lang.pct.toFixed(1)}%</span>
                </span>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* Commit log */}
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4 max-w-4xl">
          <h2 class="text-xl font-semibold text-gray-900 mb-8">Recent commits</h2>

          <div class="relative border-l border-gray-300 ml-2">
            {ghData.recentActivity.map((day) => (
              <div class="mb-6 pl-6 relative">
                <div class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-gray-400"></div>

                <p class="text-sm font-medium text-gray-900 mb-3">
                  {formatDate(day.date)}
                  <span class="ml-2 font-normal text-gray-400">{timeAgo(day.date)}</span>
                </p>

                <div class="space-y-3">
                  {day.repos.map((repo) => (
                    <div>
                      <div class="flex items-center gap-2 mb-1.5">
                        {repo.isPrivate ? (
                          <span class="text-xs font-medium text-gray-400">Private project</span>
                        ) : (
                          <a href={repo.url} target="_blank" rel="noopener noreferrer"
                            class="text-xs font-medium text-blue-600 hover:underline">
                            {repo.name}
                          </a>
                        )}
                        {repo.commits.length > 0 && (
                          <span class="text-xs text-gray-400">
                            {repo.commits.filter((c) => c.sha).length} {repo.commits.filter((c) => c.sha).length === 1 ? 'commit' : 'commits'}
                          </span>
                        )}
                      </div>
                      <div class="space-y-1">
                        {repo.commits.slice(0, 5).map((commit) => (
                          <div class="flex items-baseline gap-2 text-sm pl-2">
                            {commit.sha ? (
                              commit.url ? (
                                <a href={commit.url} target="_blank" rel="noopener noreferrer"
                                  class="font-mono text-xs text-gray-400 hover:text-blue-500 shrink-0">
                                  {commit.sha}
                                </a>
                              ) : (
                                <span class="font-mono text-xs text-gray-400 shrink-0">{commit.sha}</span>
                              )
                            ) : null}
                            <span class="text-gray-600 truncate">{commit.message}</span>
                          </div>
                        ))}
                        {repo.commits.length > 5 && (
                          <p class="text-xs text-gray-400 pl-2">
                            + {repo.commits.length - 5} more
                          </p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  {/* ===== Education & Milestones ===== */}
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-xl font-semibold text-gray-900 mb-8">Education & milestones</h2>

      <div class="space-y-6">
        {goalsWithProgress.map((goal) => (
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <div class="p-5">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-semibold text-gray-900">{goal.project}</h3>
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${
                  goal.progress === 100
                    ? 'bg-emerald-100 text-emerald-700'
                    : 'bg-blue-100 text-blue-700'
                }`}>
                  {goal.progress === 100 ? 'Completed' : `${goal.progress}%`}
                </span>
              </div>

              {/* Progress bar */}
              <div class="w-full bg-gray-100 rounded-full h-1.5 mb-4">
                <div
                  class={`h-1.5 rounded-full transition-all ${goal.progress === 100 ? 'bg-emerald-500' : 'bg-blue-500'}`}
                  style={`width: ${goal.progress}%`}
                />
              </div>

              {/* Milestones with cert links */}
              <div class="space-y-2">
                {goal.milestones.map((ms) => (
                  <div class="flex items-center gap-3 text-sm">
                    {ms.completed ? (
                      <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="currentColor" viewBox="0 0 16 16"><path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" /></svg>
                    ) : ms.current ? (
                      <span class="w-4 h-4 shrink-0 flex items-center justify-center">
                        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
                      </span>
                    ) : (
                      <span class="w-4 h-4 shrink-0 flex items-center justify-center">
                        <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                      </span>
                    )}
                    <span class={ms.completed ? 'text-gray-600' : ms.current ? 'text-gray-900 font-medium' : 'text-gray-400'}>
                      {ms.name}
                    </span>
                    {ms.cert && (
                      <a href={ms.cert} target="_blank" rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-xs text-blue-600 hover:text-blue-700 transition-colors"
                        title={`View ${ms.name} certificate`}>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        Certificate
                      </a>
                    )}
                    <span class="text-xs text-gray-400 ml-auto shrink-0">{ms.date}</span>
                  </div>
                ))}
              </div>

              {/* Project-level certificates */}
              {(goal.cert || goal.extraCert) && (
                <div class="mt-4 pt-3 border-t border-gray-100 flex flex-wrap gap-3">
                  {goal.cert && (
                    <a href={goal.cert} target="_blank" rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 border border-blue-200 text-blue-600 rounded-md hover:bg-blue-50 transition-colors">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                      {goal.certLabel || 'View Certificate'}
                    </a>
                  )}
                  {goal.extraCert && (
                    <a href={goal.extraCert} target="_blank" rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 border border-blue-200 text-blue-600 rounded-md hover:bg-blue-50 transition-colors">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                      {goal.extraCertLabel || 'Extra Certificate'}
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — subtle -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="text-gray-600 mb-4">
        Interested in working together?
      </p>
      <a
        href="mailto:Tanel.Dubolazov@gmail.com"
        class="inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        Get in touch
      </a>
    </div>
  </section>
</Layout>